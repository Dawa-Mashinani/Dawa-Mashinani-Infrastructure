# Copy this file to .env and fill in your secrets.
# Do NOT commit your .env file; it must remain private.

# Vite client environment variables must be prefixed with VITE_ to be exposed to the browser.
# Example placeholders — replace with real values from your Supabase/ngrok accounts.

# Supabase (client - anon/public key)

VITE_SUPABASE_PUBLISHABLE_KEY="from the screenshot ive provided you can see the publishable key "
VITE_SUPABASE_URL="from the screenshot ive provided you can see the url is "

# Other environment variables used by the app can go here as placeholders
# e.g. VITE_API_BASE_URL=http://localhost:5173 or VITE_SOME_OTHER_KEY=...
